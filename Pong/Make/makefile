################################################################################
# OS Detection + Shell
#
# On Windows, Make is forced to use sh.exe from MSYS2 or Git Bash.
# Unix tools (find, rm, cat, cp) are then called via their absolute path
# to prevent Windows from intercepting them with its own commands
# (e.g. FIND.EXE, which is a string search tool, not a file finder).
#
# Windows prerequisites (one is enough):
#   - MSYS2       : https://www.msys2.org/        (recommended for embedded)
#   - Git Bash    : https://git-scm.com/
#
# Update MSYS2_BIN or GITBASH_BIN if your installation path differs.
################################################################################

ifeq ($(OS),Windows_NT)
  PLATFORM := Windows

  MSYS2_BIN   := C:/msys64/usr/bin
  GITBASH_BIN := C:/Program Files/Git/usr/bin

  ifneq ($(wildcard $(MSYS2_BIN)/sh.exe),)
    SHELL    := $(MSYS2_BIN)/sh.exe
    UNIX_BIN := $(MSYS2_BIN)
  else ifneq ($(wildcard $(GITBASH_BIN)/sh.exe),)
    SHELL    := $(GITBASH_BIN)/sh.exe
    UNIX_BIN := $(GITBASH_BIN)
  else
    $(error No Unix shell found. Install MSYS2 (https://www.msys2.org) \
            or Git for Windows (https://git-scm.com) and update MSYS2_BIN.)
  endif

  # Absolute paths to Unix tools to prevent Windows from hijacking them
  FIND := $(UNIX_BIN)/find
  RM   := $(UNIX_BIN)/rm -rf
  CAT  := $(UNIX_BIN)/cat
  CPY  := $(UNIX_BIN)/cp

else
  PLATFORM := Unix
  FIND := find
  RM   := rm -rf
  CAT  := cat
  CPY  := cp
endif

# FIND_DIRS uses the absolute path to find, consistent on both platforms
FIND_DIRS = $(shell $(FIND) $(1) -mindepth 1 -type d)

################################################################################
# Path
################################################################################

SOURCES_PATH           := ../Sources
INCLUDES_PATH          := ../Includes
INCLUDES_API_PATH      := ../../../Mk/Mk/Includes
WORKING_DIRECTORY_PATH := .

################################################################################
# Guards — check that required directories exist
################################################################################

$(if $(wildcard $(SOURCES_PATH)),,      $(error SOURCES_PATH '$(SOURCES_PATH)' not found))
$(if $(wildcard $(INCLUDES_PATH)),,     $(error INCLUDES_PATH '$(INCLUDES_PATH)' not found))
$(if $(wildcard $(INCLUDES_API_PATH)),, $(error INCLUDES_API_PATH '$(INCLUDES_API_PATH)' not found))

################################################################################
# List
################################################################################

# Directories listing — uses the platform-defined FIND_DIRS function
INCLUDE_DIRECTORIES := $(call FIND_DIRS,$(INCLUDES_PATH))     $(INCLUDES_PATH) \
                       $(call FIND_DIRS,$(INCLUDES_API_PATH)) $(INCLUDES_API_PATH)
SOURCE_DIRECTORIES  := $(call FIND_DIRS,$(SOURCES_PATH))      $(SOURCES_PATH)

# List of header files
INCLUDE_FILES_LIST := $(foreach dir, $(INCLUDE_DIRECTORIES), $(wildcard $(dir)/*.h))   \
                      $(foreach dir, $(INCLUDE_DIRECTORIES), $(wildcard $(dir)/*.asm))

# List of source files
SOURCE_FILES_LIST  := $(foreach dir, $(SOURCE_DIRECTORIES), $(wildcard $(dir)/*.c))

# List of assembly files
ASM_FILES_LIST     := $(foreach dir, $(SOURCE_DIRECTORIES), $(wildcard $(dir)/*.asm))

# List of object files
OBJECT_FILES_LIST  := $(patsubst %.c,  %.o, $(SOURCE_FILES_LIST)) \
                      $(patsubst %.asm, %.o, $(ASM_FILES_LIST))

# List of dependency files (auto-generated by GCC -MMD)
DEP_FILES_LIST     := $(patsubst %.c, %.d, $(SOURCE_FILES_LIST))

# Files to clean
SU_REMOVE_FILES_LIST := $(foreach dir, $(SOURCE_DIRECTORIES), $(wildcard $(dir)/*.su))
O_REMOVE_FILES_LIST  := $(foreach dir, $(SOURCE_DIRECTORIES), $(wildcard $(dir)/*.o))
D_REMOVE_FILES_LIST  := $(foreach dir, $(SOURCE_DIRECTORIES), $(wildcard $(dir)/*.d))

################################################################################
# Toolchain
# arm-none-eabi-gcc must be in the PATH.
# On Windows: install the GNU Arm Embedded Toolchain and add it to the PATH.
################################################################################

CC     := @arm-none-eabi-gcc
LL     := @arm-none-eabi-g++
STRIP  := @arm-none-eabi-strip
OBJCPY := @arm-none-eabi-objcopy
PRINT  := @arm-none-eabi-size

################################################################################
# Artefacts
################################################################################

BUILD_ARTIFACT_NAME      := pongGameRelease
BUILD_ARTIFACT_EXTENSION := elf
BUILD_ARTIFACT           := $(BUILD_ARTIFACT_NAME)$(if $(BUILD_ARTIFACT_EXTENSION),.$(BUILD_ARTIFACT_EXTENSION),)

################################################################################
# Linker Script
################################################################################

LD_SCRIPT := -T "../Make/linker.ld"

################################################################################
# Compiler/Linker Options
################################################################################

# Options Controlling C Dialect
CDIAL_OPTIONS := -std=c18 -fno-asm -fno-builtin -fno-cond-mismatch -ffreestanding \
                 -fsigned-bitfields -fsigned-char -fsso-struct=little-endian

# Arm Options
ARM_OPTIONS := -mcpu=cortex-m7 -mthumb -mfloat-abi=hard -mfpu=fpv5-sp-d16 \
               -mno-unaligned-access -mlittle-endian

# Static Analyzer Options
ANALYZER_OPTIONS := -fanalyzer

# Debug vs Release
ifeq ($(MAKECMDGOALS),Debug)
  DEBUG_OPTIONS        := -g3 -ggdb -fno-eliminate-unused-debug-symbols
  OPTIMIZATION_OPTIONS := -O0 -fno-inline-functions -fno-short-enums -fno-move-loop-invariants
else
  DEBUG_OPTIONS        :=
  OPTIMIZATION_OPTIONS := -Ofast -fno-inline-functions -fno-short-enums -fno-move-loop-invariants
endif

# Warning Options
WARN_OPTIONS := \
  -Wpedantic -pedantic-errors -Werror -Wall -Wextra \
  -Wdouble-promotion -Wnull-dereference -Wshift-negative-value \
  -Wswitch-default -Wswitch-enum -Wswitch-bool -Wswitch-unreachable \
  -Wstrict-overflow=5 -Wduplicated-branches -Wduplicated-cond \
  -Wdiscarded-qualifiers -Wdiscarded-array-qualifiers \
  -Wincompatible-pointer-types -Wint-conversion -Wint-to-pointer-cast \
  -Wpointer-to-int-cast -Wdiv-by-zero -Wsystem-headers -Wtrampolines \
  -Wfloat-equal -Wno-traditional -Wdeclaration-after-statement \
  -Wshadow -Wshadow=local -Wunsafe-loop-optimizations -Wpointer-compare \
  -Wunused-macros -Wbad-function-cast \
  -Wcast-align -Wcast-align=strict -Wwrite-strings -Wconversion \
  -Wjump-misses-init -Waddress-of-packed-member -Wlogical-op \
  -Waggregate-return -Waggressive-loop-optimizations -Wpointer-arith \
  -Wattributes -Wstrict-prototypes -Wold-style-definition \
  --warn-missing-parameter-type -Wmissing-prototypes -Wmissing-declarations \
  -Wmultichar -Wnormalized=none -Wattribute-warning \
  -Wdeprecated -Wdeprecated-declarations -Woverflow \
  -Woverride-init-side-effects -Wpacked -Wno-packed-bitfield-compat \
  -Wpadded -Wredundant-decls -Wnested-externs -Winline \
  -Wno-long-long -Wvla -Woverlength-strings

# PIC Options (required for dynamically loaded module)
PIC_OPTIONS := -fPIC -mlong-calls

# Linking Options
LD_OPTIONS := -nostartfiles -nodefaultlibs -nolibc -nostdlib -shared -z max-page-size=65536

# H flags — forward slashes are accepted by GCC even on Windows
H_FLAGS = $(foreach dir, $(INCLUDE_DIRECTORIES), $(addprefix -I, $(dir)))

# C flags — -MMD -MP auto-generate dependency files (.d)
C_FLAGS := -x c $(CDIAL_OPTIONS) $(ARM_OPTIONS) $(ANALYZER_OPTIONS) \
           $(OPTIMIZATION_OPTIONS) $(WARN_OPTIONS) $(PIC_OPTIONS) \
           -fmessage-length=0 -nostdinc -fstack-usage \
           -MMD -MP

# Asm flags
ASM_FLAGS := -x assembler-with-cpp $(ARM_OPTIONS) $(ANALYZER_OPTIONS) \
             $(OPTIMIZATION_OPTIONS) $(WARN_OPTIONS) $(PIC_OPTIONS) \
             -fmessage-length=0 -nostdinc -fstack-usage

# Linker flags
LD_FLAGS := $(LD_OPTIONS) $(LD_SCRIPT) \
            -Wl,-Map,"$(BUILD_ARTIFACT_NAME).map" -o "$(BUILD_ARTIFACT)"

# Include auto-generated dependency files (silent if not yet present)
-include $(DEP_FILES_LIST)

################################################################################
# Clean Target
################################################################################

clean:
ifneq ($(strip $(SU_REMOVE_FILES_LIST)),)
	$(RM) $(SU_REMOVE_FILES_LIST)
endif
ifneq ($(strip $(O_REMOVE_FILES_LIST)),)
	$(RM) $(O_REMOVE_FILES_LIST)
endif
ifneq ($(strip $(D_REMOVE_FILES_LIST)),)
	$(RM) $(D_REMOVE_FILES_LIST)
endif
ifneq ($(strip $(wildcard *.map)),)
	$(RM) $(wildcard *.map)
endif
ifneq ($(strip $(wildcard *.elf)),)
	$(RM) $(wildcard *.elf)
endif
ifneq ($(strip $(wildcard *.srec)),)
	$(RM) $(wildcard *.srec)
endif
ifneq ($(strip $(wildcard *.txt)),)
	$(RM) $(wildcard *.txt)
endif

################################################################################
# Init Target
################################################################################

init:
	@printf '%s ' $(OBJECT_FILES_LIST) > $(WORKING_DIRECTORY_PATH)/objects_listing.txt

################################################################################
# Finit Target
################################################################################

finit:
	$(RM) objects_listing.txt

################################################################################
# C Source Target
################################################################################

%.o: %.c
	@echo "  CC  $<"
	$(CC) $(C_FLAGS) $(DEBUG_OPTIONS) $(H_FLAGS) -o $@ -c $<

################################################################################
# ASM Source Target
################################################################################

%.o: %.asm
	@echo "  AS  $<"
	$(CC) $(ASM_FLAGS) $(DEBUG_OPTIONS) $(H_FLAGS) -o $@ -c $<

################################################################################
# Link Target
################################################################################

$(BUILD_ARTIFACT): $(OBJECT_FILES_LIST)
	@echo "  LD  $@"
	$(LL) $(LD_FLAGS) $(DEBUG_OPTIONS) @$(WORKING_DIRECTORY_PATH)/objects_listing.txt
	@echo "  => $(BUILD_ARTIFACT) built."

################################################################################
# Print Target
################################################################################

print:
	@echo "  SIZE  $(BUILD_ARTIFACT)"
	$(PRINT) --format=berkeley --totals $(BUILD_ARTIFACT)

################################################################################
# Strip Target
################################################################################

strip:
	@echo "  STRIP  $(BUILD_ARTIFACT)"
	$(STRIP) -s $(BUILD_ARTIFACT)

################################################################################
# Composite Targets
################################################################################

# 'all' is an alias for 'Release'
all: Release

Release: init $(BUILD_ARTIFACT) print strip finit

Debug:   init $(BUILD_ARTIFACT) print finit

################################################################################
# Phony
################################################################################

.PHONY: all clean Debug Release init finit strip print
